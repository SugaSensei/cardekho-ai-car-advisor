# ==============================================================================
# CarDekho Matchmaker: Environment Variables Example
# ==============================================================================
# Copy this file to '.env' and fill in your actual credentials.

# --- AI API Keys (Provide at least one) ---
# Gemini API Key (from Google AI Studio)
GEMINI_API_KEY="AIzaSyYourGeminiAPIKeyHere"

# OpenAI API Key (from OpenAI Platform)
OPENAI_API_KEY="sk-proj-YourOpenAIAPIKeyHere"

# --- Provider & Model Configuration (Optional) ---
# Preferred AI Provider: 'openai' or 'gemini' (Defaults to 'openai' if not specified)
AI_PROVIDER="openai"

# Preferred Models to use for each provider
OPENAI_MODEL="gpt-4o"
GEMINI_MODEL="gemini-2.5-flash"
